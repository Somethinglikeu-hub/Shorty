{
  "name": "youtube-shorty-app",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rimraf dist && tsc -p tsconfig.json && shx mkdir -p dist && shx cp -r public dist/public",
    "start": "node dist/src/server.js",
    "run:headless": "node dist/src/headless.js",
    "test": "vitest run",
    "github:bootstrap": "tsx scripts/bootstrap-github-repo.ts",
    "youtube:auth-url": "tsx scripts/youtube-auth-url.ts",
    "youtube:exchange-code": "tsx scripts/youtube-exchange-code.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^144.0.0",
    "libsodium-wrappers": "^0.7.15",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "rimraf": "^6.0.1",
    "shx": "^0.4.0",
    "supertest": "^7.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
